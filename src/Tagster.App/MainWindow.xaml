<Window x:Class="Tagster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        Title="Tagster" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: tag filter panel -->
        <DockPanel Grid.Column="0" Margin="8">
            <TextBlock DockPanel.Dock="Top" Text="Tags" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBox DockPanel.Dock="Top" Margin="0,0,0,4" Padding="4,2"
                     Text="{Binding TagFilterText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Type to filter tags (Cyrillic or Latin)" />
            <TextBlock DockPanel.Dock="Bottom" Margin="0,4,0,0" Foreground="Gray" TextWrapping="Wrap"
                       Text="Click = include, Alt-click = exclude. Right-click a tag to rename or delete." />
            <Button DockPanel.Dock="Bottom" Content="Clear filters" Margin="0,6,0,0"
                    Command="{Binding ClearFiltersCommand}" />
            <ListBox ItemsSource="{Binding VisibleTags}" BorderThickness="1" BorderBrush="#E0E0E0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,1" Padding="6,3" CornerRadius="3" Cursor="Hand"
                                PreviewMouseLeftButtonUp="OnTagClick">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EEEEEE" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State}" Value="Include">
                                            <Setter Property="Background" Value="#C8E6C9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Exclude">
                                            <Setter Property="Background" Value="#FFCDD2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rename…" Click="OnRenameTag" />
                                    <MenuItem Header="Delete tag" Click="OnDeleteTag" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding Count}" Foreground="Gray" Margin="6,0,0,0" />
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- RIGHT: browser -->
        <DockPanel Grid.Column="1" Margin="0,8,8,8">
            <!-- Toolbar -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                <Button Content="←" Width="36" Margin="0,0,4,0" ToolTip="Back" Command="{Binding GoBackCommand}" />
                <Button Content="→" Width="36" Margin="0,0,4,0" ToolTip="Forward" Command="{Binding GoForwardCommand}" />
                <Button Content="↑" Width="36" Margin="0,0,8,0" ToolTip="Up" Command="{Binding GoUpCommand}" />
                <Button Content="Open archive…" DockPanel.Dock="Right" Margin="4,0,0,0" Padding="10,0" Click="OnOpenFolderClick" />
                <Button Content="Rescan" DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,0" Command="{Binding RescanCommand}" />
                <Button Content="Settings" DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,0" Click="OnSettingsClick" />
                <TextBox VerticalContentAlignment="Center" Padding="4,2"
                         Text="{Binding CurrentPath, Mode=OneWay}" KeyDown="OnAddressKeyDown" />
            </DockPanel>

            <!-- Breadcrumb -->
            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Breadcrumbs}" Margin="0,0,0,6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{Binding Name}" Padding="6,1" Margin="0,0,2,0"
                                    Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding FullPath}" />
                            <TextBlock Text="›" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,2,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Background="#F3F3F3" Padding="8,3">
                <TextBlock Text="{Binding StatusText}" />
            </Border>

            <!-- Tag editor for the selected folder -->
            <Border DockPanel.Dock="Bottom" Margin="0,6,0,0" Padding="8"
                    Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6">
                        <Run Text="Tags for " />
                        <Run Text="{Binding SelectedItem.Name, Mode=OneWay}" FontWeight="Bold" />
                    </TextBlock>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Set cover…" Padding="8,0" Margin="0,0,6,0" Click="OnSetCoverClick" />
                        <Button Content="Remove cover" Padding="8,0" Command="{Binding RemoveCoverCommand}" />
                    </StackPanel>
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                        <Button DockPanel.Dock="Right" Content="Add tag" Margin="4,0,0,0" Padding="10,0"
                                Command="{Binding AddTagCommand}" />
                        <TextBox Padding="4,2" VerticalContentAlignment="Center"
                                 Text="{Binding NewTagText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="OnNewTagKeyDown" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding SelectedItem.Tags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E3F2FD" CornerRadius="3" Margin="0,0,4,4" Padding="6,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        <Button Content="✕" Margin="6,0,0,0" Padding="2,0" BorderThickness="0"
                                                Background="Transparent" Cursor="Hand" Click="OnRemoveTagChip"
                                                ToolTip="Remove tag" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Folder grid -->
            <ListBox x:Name="FolderGrid"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     VirtualizingPanel.CacheLength="1,2"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel Orientation="Vertical" SpacingMode="StartAndEndOnly" StretchItems="False" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <EventSetter Event="MouseDoubleClick" Handler="OnItemDoubleClick" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="148" Margin="6" Padding="6">
                            <StackPanel>
                                <Grid Width="128" Height="128" HorizontalAlignment="Center">
                                    <Border Background="#FFF7F7F7" CornerRadius="4" />
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                    <Border Width="12" Height="12" CornerRadius="6" Background="#3B82F6"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                            Visibility="{Binding IsTagged, Converter={StaticResource BoolToVis}}"
                                            ToolTip="{Binding TagsTooltip}" />
                                </Grid>
                                <TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                           MaxWidth="136" Margin="0,4,0,0" ToolTip="{Binding TagsTooltip}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
