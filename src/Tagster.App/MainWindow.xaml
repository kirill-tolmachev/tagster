<ui:FluentWindow x:Class="Tagster.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
                 Title="Tagster" Width="1280" Height="820" MinWidth="940" MinHeight="600"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Right-click on a folder/file tile -->
        <ContextMenu x:Key="ItemContextMenu">
            <MenuItem Header="Open" Click="OnOpenItemClick" />
            <MenuItem Header="Open in Explorer" Click="OnOpenInExplorerClick"
                      Visibility="{Binding PlacementTarget.DataContext.IsFolder, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
            <MenuItem Header="Open parent folder" Click="OnOpenParentFolderClick"
                      Visibility="{Binding PlacementTarget.DataContext.IsFile, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
            <Separator />
            <MenuItem Header="Cut" Click="OnCutClick" InputGestureText="Ctrl+X" />
            <MenuItem Header="Copy" Click="OnCopyClick" InputGestureText="Ctrl+C" />
            <MenuItem Header="Paste" Click="OnPasteClick" InputGestureText="Ctrl+V" />
            <Separator />
            <MenuItem Header="Rename…" Click="OnRenameSelectedClick" InputGestureText="F2" />
            <MenuItem Header="Delete" Click="OnDeleteSelectedClick" InputGestureText="Del" />
        </ContextMenu>

        <!-- Right-click on empty space in the grid -->
        <ContextMenu x:Key="BackgroundContextMenu">
            <MenuItem Header="New folder" Click="OnNewFolderClick" InputGestureText="Ctrl+Shift+N" />
            <MenuItem Header="Paste" Click="OnPasteClick" InputGestureText="Ctrl+V" />
        </ContextMenu>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0" Title="Tagster" />

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="12,4,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon ArrowLeft24}" Appearance="Transparent" ToolTip="Back" Command="{Binding GoBackCommand}" />
                <ui:Button Icon="{ui:SymbolIcon ArrowRight24}" Appearance="Transparent" ToolTip="Forward" Command="{Binding GoForwardCommand}" Margin="2,0,0,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowUp24}" Appearance="Transparent" ToolTip="Up" Command="{Binding GoUpCommand}" Margin="2,0,0,0" />
                <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Transparent" ToolTip="Rescan archive" Command="{Binding RescanCommand}" Margin="2,0,8,0" />
            </StackPanel>

            <!-- Breadcrumb -->
            <Border Grid.Column="1" Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="{Binding Name}" Appearance="Transparent" Padding="6,2"
                                               Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                               CommandParameter="{Binding FullPath}" />
                                    <TextBlock Text="›" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="2,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                <ui:Button Content="Open" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Primary" Click="OnOpenFolderClick" />
                <ui:Button Icon="{ui:SymbolIcon Settings24}" Appearance="Transparent" ToolTip="Settings" Click="OnSettingsClick" Margin="6,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Main content: Find / Browse / Inspect -->
        <Grid Grid.Row="2" Margin="12,0,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="240" />
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="330" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: tag filter -->
            <ui:Card Grid.Column="0" Margin="0,0,8,0" Padding="0">
                <DockPanel Margin="12">
                    <DockPanel DockPanel.Dock="Top" Margin="2,0,0,8">
                        <ComboBox DockPanel.Dock="Right" MinWidth="104" FontSize="12" VerticalAlignment="Center"
                                  ToolTip="Sort tags"
                                  ItemsSource="{Binding TagSortOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding TagSort, Mode=TwoWay}" />
                        <TextBlock Text="Tags" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    </DockPanel>
                    <ui:TextBox DockPanel.Dock="Top" PlaceholderText="Filter tags…" Icon="{ui:SymbolIcon Search24}"
                                ClearButtonEnabled="True" Margin="0,0,0,8"
                                Text="{Binding TagFilterText, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Active filters -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8"
                                Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}">
                        <DockPanel Margin="2,0,0,4">
                            <TextBlock Text="Active filters" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ui:Button DockPanel.Dock="Right" Content="Clear" Appearance="Transparent" Padding="6,0" FontSize="12"
                                       HorizontalAlignment="Right" Command="{Binding ClearFiltersCommand}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding ActiveFilters}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Margin="0,0,4,4" Padding="8,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Include">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Exclude">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <ui:Button Icon="{ui:SymbolIcon Dismiss16}" Appearance="Transparent" Padding="2" Margin="4,0,-4,0"
                                                       Click="OnRemoveActiveFilter" ToolTip="Remove" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,6,0,0" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" Margin="2,8,0,0" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="＋ include (must have) · − exclude (must not have). Right-click a tag to rename or delete." />

                    <ListBox ItemsSource="{Binding VisibleTags}" Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Margin="0,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding State}" Value="Include">
                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding State}" Value="Exclude">
                                                    <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename…" Click="OnRenameTag" />
                                            <MenuItem Header="Delete tag" Click="OnDeleteTag" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding Count}" Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon Add24}" Appearance="Transparent" Padding="6,2"
                                                   ToolTip="Include" Click="OnTagIncludeClick" />
                                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Subtract24}" Appearance="Transparent" Padding="6,2" Margin="2,0,0,0"
                                                   ToolTip="Exclude" Click="OnTagExcludeClick" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </ui:Card>

            <!-- CENTER: folder grid + empty states -->
            <Grid Grid.Column="1">
                <ListBox x:Name="FolderGrid"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         SelectionMode="Extended"
                         SelectionChanged="OnGridSelectionChanged"
                         KeyDown="OnGridKeyDown"
                         ContextMenu="{StaticResource BackgroundContextMenu}"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="OnGridPreviewLeftButtonDown"
                         PreviewMouseMove="OnGridPreviewMouseMove"
                         DragOver="OnGridDragOver"
                         Drop="OnGridDrop"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Visible"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         VirtualizingPanel.CacheLengthUnit="Page"
                         VirtualizingPanel.CacheLength="1,2"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer Style="{x:Null}" Focusable="False" CanContentScroll="True"
                                          HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <vwp:VirtualizingWrapPanel Orientation="Horizontal" SpacingMode="StartAndEndOnly" StretchItems="False" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                            <EventSetter Event="MouseDoubleClick" Handler="OnItemDoubleClick" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnItemRightButtonDown" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="156" Margin="5" Padding="8" CornerRadius="8"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCut}" Value="True">
                                                <Setter Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Width="128" Height="128" HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="4" />
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                        <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                                Visibility="{Binding IsTagged, Converter={StaticResource BoolToVis}}"
                                                ToolTip="{Binding TagsTooltip}" />
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxWidth="140" Margin="0,6,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               ToolTip="{Binding TagsTooltip}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty / loading states -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="320"
                            Visibility="{Binding ShowOpenArchivePrompt, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="40" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Open an archive to begin" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <TextBlock Text="Choose the folder that contains your author folders. Tagster scans it for tags."
                               TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:Button Content="Open archive" Icon="{ui:SymbolIcon FolderOpen24}" Appearance="Primary"
                               HorizontalAlignment="Center" Margin="0,16,0,0" Click="OnOpenFolderClick" />
                </StackPanel>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="320"
                            Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="Search24" FontSize="36" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No folders match these filters" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <ui:Button Content="Clear filters" Appearance="Secondary" HorizontalAlignment="Center" Margin="0,8,0,0"
                               Command="{Binding ClearFiltersCommand}" />
                </StackPanel>

                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="This folder is empty."
                           Visibility="{Binding ShowEmptyFolder, Converter={StaticResource BoolToVis}}" />

                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <!-- RIGHT: inspector -->
            <ui:Card Grid.Column="2" Margin="8,0,0,0" Padding="0">
                <Grid Margin="16">
                    <!-- Nothing selected -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="240"
                                Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVis}}">
                        <ui:SymbolIcon Symbol="Tag24" FontSize="32" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="Select a folder to edit its tags and cover, or a file to preview it."
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- A folder is selected -->
                    <DockPanel Visibility="{Binding SelectedIsFolder, Converter={StaticResource BoolToVis}}">
                        <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedItem.Name}" FontSize="16" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                        <Border DockPanel.Dock="Top" Height="200" CornerRadius="6" Margin="0,0,0,12"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <Image Source="{Binding SelectedItem.Thumbnail}" Stretch="Uniform" Margin="8"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ui:Button DockPanel.Dock="Top" Content="Open in Explorer" Icon="{ui:SymbolIcon Open24}" Appearance="Secondary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,16" Click="OnOpenSelectedClick" />

                        <!-- Cover actions pinned to the bottom -->
                        <StackPanel DockPanel.Dock="Bottom">
                            <Border Height="1" Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,12" />
                            <TextBlock Text="Cover" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Set cover…" Icon="{ui:SymbolIcon ImageEdit24}" Appearance="Secondary" Click="OnSetCoverClick" />
                                <ui:Button Content="Remove" Appearance="Transparent" Margin="6,0,0,0" Command="{Binding RemoveCoverCommand}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Tags editor -->
                        <TextBlock DockPanel.Dock="Top" Text="Tags" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <ui:Button DockPanel.Dock="Right" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Margin="6,0,0,0"
                                       ToolTip="Add tag" Click="OnAddTagClick" />
                            <ui:AutoSuggestBox x:Name="AddTagBox" PlaceholderText="Add a tag…"
                                               ClearButtonEnabled="True"
                                               Text="{Binding NewTagText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               OriginalItemsSource="{Binding AddTagSuggestions}"
                                               TextChanged="OnAddTagTextChanged"
                                               QuerySubmitted="OnAddTagQuerySubmitted" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding SelectedItem.Tags}" VerticalAlignment="Top">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                                            CornerRadius="4" Margin="0,0,4,4" Padding="8,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <ui:Button Icon="{ui:SymbolIcon Dismiss16}" Appearance="Transparent" Padding="2" Margin="4,0,-4,0"
                                                       ToolTip="Remove tag" Click="OnRemoveTagChip" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>

                    <!-- A file is selected: preview + open externally (files aren't tagged) -->
                    <StackPanel Visibility="{Binding SelectedIsFile, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding SelectedItem.Name}" FontSize="16" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                        <Border Height="200" CornerRadius="6" Margin="0,0,0,12"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}">
                            <Image Source="{Binding SelectedItem.Thumbnail}" Stretch="Uniform" Margin="8"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <ui:Button Content="Open file" Icon="{ui:SymbolIcon Open24}" Appearance="Secondary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Click="OnOpenSelectedClick" />
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" Padding="14,5">
            <DockPanel>
                <ui:ProgressRing DockPanel.Dock="Left" IsIndeterminate="True" Width="14" Height="14" Margin="0,0,8,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
