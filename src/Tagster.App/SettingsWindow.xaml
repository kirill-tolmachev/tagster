<ui:FluentWindow x:Class="Tagster.App.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Tagster settings" Width="520" Height="360"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Settings" />

        <DockPanel Grid.Row="1" Margin="24,8,24,20">
            <ui:Button DockPanel.Dock="Bottom" Content="Close" Appearance="Secondary" MinWidth="92"
                       HorizontalAlignment="Right" IsCancel="True" Click="OnClose" />
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" MinHeight="16" TextWrapping="Wrap"
                       Margin="0,12,0,12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <StackPanel>
                <TextBlock Text="Windows Explorer" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:ToggleSwitch Content="Show Tagster in the folder right-click menu"
                                 IsChecked="{Binding ExplorerMenuEnabled, Mode=TwoWay}" />
                <TextBlock Text="Adds “Open in Tagster” and “Edit tags in Tagster” to folders." FontSize="12"
                           Margin="0,4,0,18" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                <TextBlock Text="Startup" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:ToggleSwitch Content="Reopen the last archive when Tagster starts"
                                 IsChecked="{Binding ReopenLastArchive, Mode=TwoWay}" />
                <TextBlock Text="Last archive" FontSize="12" Margin="0,16,0,2"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="{Binding LastArchivePath, TargetNullValue=(none)}" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</ui:FluentWindow>
