# Normalize line endings: LF in the repository, native on checkout.
* text=auto

# Source and config files are text.
*.cs             text
*.csproj         text
*.slnx           text
*.sln            text
*.props          text
*.targets        text
*.json           text
*.md             text
*.xml            text
*.editorconfig   text

# Binary assets (no EOL conversion) — used by the cover feature and packaging.
*.ico   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.db    binary
